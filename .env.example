# --- Nostr auth (Phase 2) ---

# Database — Neon serverless Postgres. Required to COMPLETE sign-in (the login
# endpoint upserts a `users` row keyed by pubkey) and for the session route.
# Get a free database at https://neon.tech and paste its connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT signing secret for the session cookie. Required in production.
# Dev/test fall back to a built-in dev key, so local dev works without it.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=""

# Public base URL — used to build NIP-46 connect URIs / the NIP-98 `u` tag when
# `window` is unavailable (server). In the browser it falls back to
# window.location.origin.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
